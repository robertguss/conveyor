{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.local/schemas/conveyor.plan@1",
  "title": "Conveyor Human Plan",
  "description": "Phase 0/1 normalized human-authored plan contract consumed by Conveyor's deterministic conductor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "title",
    "project",
    "goal",
    "non_goals",
    "autonomy_level",
    "cutline",
    "requirements",
    "verification_commands",
    "decisions",
    "slices"
  ],
  "properties": {
    "schema_version": {
      "const": "conveyor.plan@1"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "name",
        "repository"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "autonomy_level": {
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4"
      ]
    },
    "cutline": {
      "enum": [
        "TRACER_REQUIRED",
        "TRUST_REQUIRED"
      ]
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requirement_id",
          "title",
          "source_ref",
          "status",
          "acceptance_criteria"
        ],
        "properties": {
          "requirement_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source_ref": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "section"
            ],
            "properties": {
              "section": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "status": {
            "enum": [
              "ready",
              "open",
              "deferred",
              "out_of_scope"
            ]
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "ac_id",
                "text"
              ],
              "properties": {
                "ac_id": {
                  "type": "string",
                  "minLength": 1
                },
                "text": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "verification_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command_id",
          "acceptance_refs",
          "command"
        ],
        "properties": {
          "command_id": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "command": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_id",
          "title",
          "rationale"
        ],
        "properties": {
          "decision_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "decision_type": {
            "enum": [
              "architecture",
              "scope_exclusion",
              "contract_change",
              "acceptance_weakening",
              "policy_weakening",
              "external_integration"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "artifact_digests": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "human_approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "approval_id",
          "approval_type",
          "actor",
          "target",
          "reason",
          "artifact_digests"
        ],
        "properties": {
          "approval_id": {
            "type": "string",
            "minLength": 1
          },
          "approval_type": {
            "enum": [
              "contract_change",
              "acceptance_weakening",
              "policy_weakening",
              "external_integration"
            ]
          },
          "actor": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "artifact_digests": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "contract_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "change_id",
          "change_type",
          "summary",
          "rationale",
          "decision_refs",
          "approval_refs",
          "artifact_digests"
        ],
        "properties": {
          "change_id": {
            "type": "string",
            "minLength": 1
          },
          "change_type": {
            "enum": [
              "contract_change",
              "acceptance_weakening",
              "policy_weakening",
              "external_integration"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "decision_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "approval_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "artifact_digests": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "slices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slice_id",
          "title",
          "requirement_refs",
          "decision_refs",
          "verification_refs",
          "likely_files",
          "conflict_domains",
          "autonomy_level"
        ],
        "properties": {
          "slice_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "requirement_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "decision_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "bug_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "improvement_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "verification_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "likely_files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "conflict_domains": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "autonomy_level": {
            "enum": [
              "L0",
              "L1",
              "L2",
              "L3",
              "L4"
            ]
          }
        }
      }
    }
  }
}
