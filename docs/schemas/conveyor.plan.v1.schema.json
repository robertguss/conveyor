{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.local/schemas/conveyor.plan@1",
  "title": "Conveyor Human Plan",
  "description": "Phase 0/1 human-authored plan contract consumed by Conveyor's deterministic conductor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "title",
    "objective",
    "autonomy_level",
    "cutline",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "conveyor.plan@1"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "autonomy_level": {
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4"
      ]
    },
    "cutline": {
      "enum": [
        "TRACER_REQUIRED",
        "TRUST_REQUIRED"
      ]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "title",
          "acceptance",
          "evidence_required"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence_required": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
