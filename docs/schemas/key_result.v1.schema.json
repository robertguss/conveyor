{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.local/schemas/key_result@1",
  "title": "Key Result Artifact",
  "description": "Structured station result that can be referenced by evidence, review, and gate outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "result_id",
    "run_id",
    "station_key",
    "result_type",
    "status",
    "summary",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "key_result@1"
    },
    "result_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "station_key": {
      "type": "string",
      "minLength": 1
    },
    "result_type": {
      "enum": [
        "test",
        "quality",
        "policy",
        "acceptance",
        "command",
        "canary"
      ]
    },
    "status": {
      "enum": [
        "pass",
        "fail",
        "blocked",
        "skipped",
        "warning"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
