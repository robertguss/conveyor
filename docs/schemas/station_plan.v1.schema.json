{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.local/schemas/station_plan@1",
  "title": "Station Plan",
  "description": "A single deterministic station instruction packet derived from the run specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "station_key",
    "run_id",
    "intent",
    "inputs",
    "expected_outputs",
    "timeout_seconds"
  ],
  "properties": {
    "schema_version": {
      "const": "station_plan@1"
    },
    "station_key": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "object"
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    }
  }
}
