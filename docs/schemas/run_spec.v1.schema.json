{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.local/schemas/run_spec@1",
  "title": "Run Specification",
  "description": "Immutable run inputs resolved before station execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "plan_id",
    "created_at",
    "conductor_version",
    "artifact_schema_versions",
    "stations"
  ],
  "properties": {
    "schema_version": {
      "const": "run_spec@1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "conductor_version": {
      "type": "string",
      "minLength": 1
    },
    "artifact_schema_versions": {
      "type": "object",
      "description": "Public artifact schema versions recorded in this immutable run input.",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_.]*$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_.]*@[0-9]+$"
      }
    },
    "stations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
