{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.local/schemas/evidence@1",
  "title": "Machine Evidence Record",
  "description": "A conductor-produced machine evidence record for one run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "run_id",
    "slice_id",
    "station_key",
    "artifact_type",
    "path",
    "sha256",
    "summary",
    "redaction_status",
    "agent",
    "base_commit",
    "head_commit",
    "autonomy_level",
    "changed_files",
    "diff_ref",
    "conductor_commands",
    "acceptance",
    "quality_refs",
    "policy_violations",
    "review_result",
    "gate_result",
    "known_risks",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "evidence@1"
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "slice_id": {
      "type": "string",
      "minLength": 1
    },
    "station_key": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "enum": [
        "report"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "redaction_status": {
      "enum": [
        "not_required",
        "redacted",
        "blocked"
      ]
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "session_id",
        "profile_id"
      ],
      "properties": {
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "profile_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "base_commit": {
      "type": "string",
      "minLength": 1
    },
    "head_commit": {
      "type": "string",
      "minLength": 1
    },
    "autonomy_level": {
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4"
      ]
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "diff_ref": {
      "type": "string",
      "minLength": 1
    },
    "conductor_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command_id",
          "command",
          "exit_code",
          "status",
          "evidence_ref"
        ],
        "properties": {
          "command_id": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "exit_code": {
            "type": "integer"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "blocked",
              "not_run"
            ]
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mapping_complete",
        "criteria",
        "results"
      ],
      "properties": {
        "mapping_complete": {
          "const": true
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "criterion_id",
              "description"
            ],
            "properties": {
              "criterion_id": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "criterion_id",
              "status",
              "evidence_refs",
              "verified_by",
              "verification_source"
            ],
            "properties": {
              "criterion_id": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "enum": [
                  "pass",
                  "fail",
                  "blocked",
                  "not_run"
                ]
              },
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "verified_by": {
                "const": "conductor"
              },
              "verification_source": {
                "const": "independent_conductor_verification"
              }
            }
          }
        }
      }
    },
    "quality_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "policy_violations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "review_result": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "decision"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gate_result": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "decision"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "known_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk_id",
          "severity",
          "summary"
        ],
        "properties": {
          "risk_id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "created_by",
        "source",
        "agent_self_report_used"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "minLength": 1
        },
        "created_by": {
          "const": "conductor"
        },
        "source": {
          "const": "independent_conductor_verification"
        },
        "agent_self_report_used": {
          "const": false
        }
      }
    }
  }
}
