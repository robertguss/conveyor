{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.local/schemas/run_bundle@1",
  "title": "Run Bundle Index",
  "description": "Reproducible index of the artifacts produced by one Conveyor run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "run_id",
    "created_at",
    "root_digest",
    "artifact_schema_versions",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "run_bundle@1"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "root_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifact_schema_versions": {
      "type": "object",
      "description": "Public artifact schema versions used by this projected report bundle.",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_.]*$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_.]*@[0-9]+$"
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "artifact_role",
          "path",
          "sha256"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "minLength": 1
          },
          "artifact_role": {
            "enum": [
              "manifest",
              "evidence",
              "review",
              "gate",
              "run_bundle",
              "provenance",
              "key_result",
              "dossier",
              "pr_body",
              "command_log",
              "diff"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
