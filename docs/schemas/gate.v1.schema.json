{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.local/schemas/gate@1",
  "title": "Gate Decision",
  "description": "A deterministic gate outcome over evidence, reviews, and policy checks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gate_id",
    "run_id",
    "gate_name",
    "decision",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "const": "gate@1"
    },
    "gate_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "gate_name": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "blocked"
            ]
          },
          "finding_ref": {
            "type": "string"
          }
        }
      }
    }
  }
}
