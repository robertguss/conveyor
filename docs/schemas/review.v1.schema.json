{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.local/schemas/review@1",
  "title": "Review Record",
  "description": "Human or agent review result with explicit findings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "run_id",
    "reviewer",
    "verdict",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "review@1"
    },
    "review_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "enum": [
        "pass",
        "needs_changes",
        "blocked"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "message"
        ],
        "properties": {
          "severity": {
            "enum": [
              "info",
              "warning",
              "error"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          }
        }
      }
    }
  }
}
